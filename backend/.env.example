# App
PORT=5000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_change_this

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=leadflow
DB_USER=postgres
DB_PASSWORD=your_db_password

# Email (Brevo/SendGrid/Mailgun - all free tiers available)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_email
SMTP_PASS=your_brevo_smtp_key
EMAIL_FROM=leads@yourcompany.com
EMAIL_FROM_NAME=YourCompany CRM

# Twilio (WhatsApp + SMS + Voice calls)
# Free trial gives $15 credit - enough for hundreds of messages
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# AI Voice (Vapi.ai - cheapest AI calling at ~$0.05/min)
VAPI_API_KEY=your_vapi_api_key
VAPI_ASSISTANT_ID=your_assistant_id

# Claude AI (for lead scoring + message drafting)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
